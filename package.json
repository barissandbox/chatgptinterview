{
  "name": "chatgpt-interview",
  "version": "1.2.0",
  "description": "ChatGPT Interview is a local Chrome extension that helps with live interview preparation and practice.",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && node scripts/build.mjs",
    "dev": "npm run clean && node scripts/build.mjs --watch",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "pdfjs-dist": "^5.7.284"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=20"
  }
}
