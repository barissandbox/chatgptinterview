{
  "manifest_version": 3,
  "name": "ChatGPT Interview",
  "description": "ChatGPT Interview is a local Chrome extension that helps with live interview preparation and practice.",
  "version": "1.2.0",
  "icons": {
    "16": "icons/chatgpt-icon.png",
    "32": "icons/chatgpt-icon.png",
    "48": "icons/chatgpt-icon.png",
    "128": "icons/chatgpt-icon.png"
  },
  "action": {
    "default_title": "ChatGPT Interview",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/chatgpt-icon.png",
      "32": "icons/chatgpt-icon.png",
      "48": "icons/chatgpt-icon.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "offscreen",
    "sidePanel",
    "tabCapture",
    "tabs"
  ],
  "host_permissions": [
    "https://auth.openai.com/*",
    "https://chatgpt.com/*",
    "https://api.deepgram.com/*",
    "https://registry.npmjs.org/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/chatgpt-icon.png", "audio-worklet.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
